---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import StockCard from '../../components/StockCard.astro';
import StockChart from '../../components/StockChart.astro';
import StockSearch from '../../components/StockSearch.astro';
import { SITE } from '../../config';
import krx from '../../data/krx.json';

const quotesEnabled = SITE.quoteApi.startsWith('http');

export async function getStaticPaths() {
  return krx.map((s) => ({ params: { code: s.code }, props: { stock: s } }));
}

const { stock } = Astro.props;
const { code } = Astro.params;

const related = (await getCollection('posts', ({ data }) => !data.draft))
  .filter((p) => p.data.tickers.some((t) => t.code === code))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const fmt = (d: Date) => d.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout
  title={`${stock.name} (${stock.code}) 시세·분석`}
  description={`${stock.name}(${stock.code}) 실시간 시세와 관련 분석 글 모음.`}
  canonicalPath={`/stock/${code}/`}
  noindex={related.length === 0}
>
  <div class="wrap stock-page">
    <div class="top"><StockSearch /></div>

    <header class="stk-head">
      <span class="eyebrow">{stock.market}</span>
      <h1>{stock.name} <span class="stk-code">{stock.code}</span></h1>
    </header>

    {quotesEnabled && <StockCard code={stock.code} name={stock.name} />}
    <StockChart code={stock.code} name={stock.name} />

    <section class="related">
      <h2 class="sec-title">이 종목을 다룬 글</h2>
      {related.length === 0 ? (
        <p class="muted">아직 이 종목에 대한 글이 없습니다.</p>
      ) : (
        <div class="post-grid">
          {related.map((p) => (
            <a class="post-card" href={`/posts/${p.id}/`}>
              <div class="pc-cover"><img src={p.data.cover ?? '/images/cover-skhynix.svg'} alt="" loading="lazy" /></div>
              <div class="pc-body">
                <span class="pc-date">{fmt(p.data.pubDate)}</span>
                <span class="pc-title">{p.data.title}</span>
                <p class="pc-desc">{p.data.description}</p>
              </div>
            </a>
          ))}
        </div>
      )}
    </section>
  </div>
</BaseLayout>

<style>
  .stock-page .top { margin: 26px 0 22px; }
  .stk-head { margin: 6px 0 20px; }
  .stk-head h1 { font-size: 1.9rem; margin: 6px 0 0; letter-spacing: -0.02em; }
  .stk-code { font-size: 0.95rem; font-weight: 600; color: var(--faint); font-variant-numeric: tabular-nums; }
  .related { margin-top: 40px; }
  .sec-title { font-size: 1.05rem; color: var(--muted); font-weight: 700; margin: 0 0 18px; }
</style>
