---
import { getCollection } from 'astro:content';

interface Props {
  currentId: string;
  limit?: number;
}
const { currentId, limit = 5 } = Astro.props;

// 주제 기반 관련글: 같은 종목코드 또는 공통 태그가 많은 글 우선(교집합 점수 내림차순),
// 동점·무관은 최신순. 부족하면 최신 글로 자연히 보충된다(점수 0도 날짜순으로 채워짐).
const all = (await getCollection('posts', ({ data }) => !data.draft));
const current = all.find((p) => p.id === currentId);
const myCodes = new Set((current?.data.tickers ?? []).map((t) => t.code));
const myTags = new Set(current?.data.tags ?? []);

const recent = all
  .filter((p) => p.id !== currentId)
  .map((p) => {
    const codeHits = p.data.tickers.filter((t) => myCodes.has(t.code)).length;
    const tagHits = p.data.tags.filter((t) => myTags.has(t)).length;
    return { p, score: codeHits + tagHits };
  })
  .sort((a, b) => b.score - a.score || b.p.data.pubDate.getTime() - a.p.data.pubDate.getTime())
  .slice(0, limit)
  .map((s) => s.p);

const fmt = (d: Date) => d.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' });
---

{recent.length > 0 && (
  <section class="related">
    <div class="rel-head">
      <h2>이어서 읽어보세요</h2>
      <a href="/posts/" class="rel-all">전체 글 →</a>
    </div>
    <div class="post-list">
      {recent.map((p) => (
        <a class="pl-item" href={`/posts/${p.id}/`}>
          <span class="pl-title">{p.data.title}</span>
          <time class="pl-date" datetime={p.data.pubDate.toISOString()}>{fmt(p.data.pubDate)}</time>
        </a>
      ))}
    </div>
  </section>
)}

<style>
  .related { margin: 20px 0 10px; }
  .rel-head { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 14px; }
  .rel-head h2 { font-size: 1.3rem; margin: 0; letter-spacing: -0.02em; }
  .rel-all { font-size: 0.88rem; font-weight: 600; color: var(--muted); }
  .rel-all:hover { color: var(--accent); }
</style>
