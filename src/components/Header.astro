---
import { SITE, NAV } from '../config';
---

<header class="site-header">
  <div class="wide inner">
    <a href="/" class="brand">
      <span class="brand-mark">O</span>
      <span class="brand-text">{SITE.title}</span>
    </a>
    <nav>
      {NAV.map((n) => <a href={n.href}>{n.label}</a>)}
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--border);
    background: color-mix(in srgb, var(--bg) 82%, transparent);
    backdrop-filter: saturate(1.4) blur(10px);
    position: sticky; top: 0; z-index: 20;
  }
  .inner {
    display: flex; align-items: center; justify-content: space-between;
    height: 62px;
  }
  .brand {
    display: inline-flex; align-items: center; gap: 9px;
    font-weight: 800; font-size: 1.14rem; color: var(--fg); letter-spacing: -0.02em;
  }
  .brand:hover { text-decoration: none; }
  .brand-mark {
    display: inline-grid; place-items: center;
    width: 28px; height: 28px; border-radius: 8px;
    background: var(--accent); color: #fff; font-size: 0.9rem; font-weight: 800;
  }
  nav { display: flex; gap: 22px; }
  nav a { color: var(--muted); font-size: 0.94rem; font-weight: 600; }
  nav a:hover { color: var(--fg); text-decoration: none; }
</style>
